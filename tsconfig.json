{
  "compilerOptions": {
    // TypeScript는 강제 에러가 아닌 참고(IDE 힌트) 용도로만 사용합니다.
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    // JS 파일도 허용 — .js / .jsx 파일도 함께 사용 가능
    "allowJs": true,
    "checkJs": false,

    // 빌드는 Vite가 담당, tsc는 타입 검사 참고용
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    // 엄격 검사 OFF — 타입은 힌트 수준으로만
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  "include": ["src"]
}
